# Copy this file to `.env` and fill in your own Garmin Connect login —
# or skip the copying and just run the setup script (setup.ps1 on Windows,
# setup.sh on macOS/Linux), which creates .env for you.
# NEVER commit or share your .env — see SECURITY.md.
GA_GARMIN_EMAIL=you@example.com
GA_GARMIN_PASSWORD=changeme

# Optional: turns on the AI Coach chat page. Get a key at
# https://platform.claude.com. Without it the Coach is off and the rest of
# the app works normally. Using the Coach sends your local analytics
# summaries to Anthropic's API — see SECURITY.md.
# GA_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides (defaults shown)
# GA_DATABASE_URL=sqlite:///data/garmin.db
# GA_GARMIN_TOKENS_DIR=data/garmin_tokens
# GA_ENVIRONMENT=dev
