# Copy this file to `.env` and fill in your own Garmin Connect login —
# or skip the copying and just run the setup script (setup.ps1 on Windows,
# setup.sh on macOS/Linux), which creates .env for you.
# NEVER commit or share your .env — see SECURITY.md.
GA_GARMIN_EMAIL=you@example.com
GA_GARMIN_PASSWORD=changeme

# --- Running on a server (see DEPLOY.md) ---------------------------------
# App login password. Unset = no login (safe ONLY on a trusted localhost).
# REQUIRED once you run beyond this machine: with GA_ENVIRONMENT=prod the app
# refuses to start without it, and every /api call then needs a login. Pick a
# strong password; generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# GA_APP_PASSWORD=

# Morning Readiness Brief via Telegram (see DEPLOY.md for the 2-minute setup:
# talk to @BotFather for the token, @userinfobot for your chat id). Both must be
# set, and notify.enabled: true in config/config.yaml, for the daily push. The
# brief includes an AI-recommended workout when GA_ANTHROPIC_API_KEY (below) is
# set; without it, a safe rule-based workout is used. Set your goal in config.yaml.
# GA_TELEGRAM_BOT_TOKEN=
# GA_TELEGRAM_CHAT_ID=

# Optional: powers the AI Coach chat, the morning brief's workout suggestion,
# and (only if you also set ai_insights.enabled: true in config/config.yaml)
# the optional "Generate deeper AI analysis" button on metric pages. Get a key
# at https://platform.claude.com. Without it, all of these stay off and the rest
# of the app — including the free local metric insights — works normally. Any AI
# feature sends only compact local summaries to Anthropic's API, never raw
# health records — see SECURITY.md.
# GA_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: shared secret guarding the watch feed (/api/watch/*). Leave unset
# on localhost/the simulator (the feed is open there). Set it ONLY if you
# expose the backend beyond your own machine (e.g. through a tunnel for a real
# watch), so the public endpoint isn't wide open. When set, /api/watch/*
# requires a matching ?token=. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# GA_WATCH_TOKEN=

# Optional overrides (defaults shown)
# GA_DATABASE_URL=sqlite:///data/garmin.db
# GA_GARMIN_TOKENS_DIR=data/garmin_tokens
# GA_ENVIRONMENT=dev   # set to "prod" when running in Docker / on a server
